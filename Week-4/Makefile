####### Compile

codeslot.o: codeslot.cpp codeslot.h \
		slot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o codeslot.o codeslot.cpp

deur.o: deur.cpp deur.h \
		deurdefs.h \
		slot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o deur.o deur.cpp

draaideur.o: draaideur.cpp draaideur.h \
		deur.h \
		deurdefs.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o draaideur.o draaideur.cpp

hallsensor.o: hallsensor.cpp hallsensor.h \
		sensor.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o hallsensor.o hallsensor.cpp

main.o: main.cpp mainwindow.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

mainwindow.o: mainwindow.cpp mainwindow.h \
		ui_mainwindow.h \
		codeslot.h \
		slot.h \
		deur.h \
		draaideur.h \
		hallsensor.h \
		sensor.h \
		schuifdeur.h \
		sleutelslot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mainwindow.o mainwindow.cpp

sleutelslot.o: sleutelslot.cpp sleutelslot.h \
		slot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o sleutelslot.o sleutelslot.cpp

schuifdeur.o: schuifdeur.cpp schuifdeur.h \
		deur.h \
		deurdefs.h \
		sensor.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o schuifdeur.o schuifdeur.cpp

sensor.o: sensor.cpp sensor.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o sensor.o sensor.cpp

qrc_resources.o: qrc_resources.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_resources.o qrc_resources.cpp

moc_mainwindow.o: moc_mainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mainwindow.o moc_mainwindow.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/gebouw-3/bin || mkdir -p $(INSTALL_ROOT)/opt/gebouw-3/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/gebouw-3/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/gebouw-3/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/gebouw-3/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/gebouw-3/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

